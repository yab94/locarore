# Copier ce fichier en .env et renseigner les valeurs réelles

# Environnement : dev (erreurs affichées) ou prod (erreurs masquées)
APP_ENV=prod

ADMIN_PASSWORD=changeme

DB_HOST=changeme
DB_NAME=changeme
DB_USER=changeme
DB_PASSWORD=changeme    

FTP_LOGIN="changeme"
FTP_PASSWORD="changeme"

# SMTP — paramètres d'envoi d'email
SMTP_HOST=changeme
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USER=changeme
SMTP_PASSWORD=changeme
SMTP_FROM_EMAIL=changeme@example.com
SMTP_FROM_NAME="Locarore"
FTP_HOST="changeme"

GA_MEASUREMENT_ID=G-XXXXXXXXXX
AXEPTIO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx   # depuis app.axept.io
AXEPTIO_VERSION=locarore-fr  