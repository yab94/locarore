# Dépendances
/vendor/
/node_modules/

# Uploads (fichiers ignorés, mais la structure de dossiers est trackée via .gitkeep)
/public/assets/uploads/*
!/public/assets/uploads/.gitkeep
!/public/assets/uploads/products/
/public/assets/uploads/products/*
!/public/assets/uploads/products/.gitkeep

# Docker volumes
/docker/mysql-data/

# Logs
*.log
/var/log/

# PHP
*.cache

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Environnement (les valeurs réelles ne se committent pas)
.env*
.env.local
# .env.example est volontairement tracké (modèle sans valeurs sensibles)
